<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1A1A2E">

    <!-- Toolbar: device selector + action buttons in one row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="8dp"
        android:background="#16213E">

        <!-- Device spinner (shows known devices or registering state) -->
        <Spinner
            android:id="@+id/device_spinner"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="@android:drawable/btn_dropdown"
            android:popupBackground="#16213E" />

        <Button
            android:id="@+id/btn_discoverable"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginStart="6dp"
            android:minWidth="100dp"
            android:text="Pair"
            android:textSize="11sp"
            style="?attr/materialButtonOutlinedStyle" />

        <Button
            android:id="@+id/btn_screenshot"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginStart="6dp"
            android:text="Screenshot"
            android:textSize="11sp"
            style="?attr/materialButtonOutlinedStyle" />

        <Button
            android:id="@+id/btn_stream"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginStart="6dp"
            android:text="Stream"
            android:textSize="11sp"
            android:visibility="gone"
            style="?attr/materialButtonOutlinedStyle" />

        <Button
            android:id="@+id/btn_clear"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginStart="6dp"
            android:text="Clear"
            android:textSize="11sp"
            style="?attr/materialButtonOutlinedStyle" />

        <Button
            android:id="@+id/btn_focus"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginStart="6dp"
            android:text="Focus"
            android:textSize="11sp"
            style="?attr/materialButtonOutlinedStyle" />

        <Button
            android:id="@+id/btn_settings"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginStart="6dp"
            android:text="Settings"
            android:textSize="11sp"
            style="?attr/materialButtonOutlinedStyle" />
    </LinearLayout>

    <!-- Shortcut buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingBottom="4dp"
        android:background="#16213E">

        <Button
            android:id="@+id/btn_undo"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginEnd="6dp"
            android:text="Undo"
            android:textSize="11sp"
            style="?attr/materialButtonOutlinedStyle" />

        <Button
            android:id="@+id/btn_redo"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginEnd="6dp"
            android:text="Redo"
            android:textSize="11sp"
            style="?attr/materialButtonOutlinedStyle" />

        <Button
            android:id="@+id/btn_brush_small"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginEnd="6dp"
            android:text="[-]"
            android:textSize="11sp"
            style="?attr/materialButtonOutlinedStyle" />

        <Button
            android:id="@+id/btn_brush_large"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="[+]"
            android:textSize="11sp"
            style="?attr/materialButtonOutlinedStyle" />
    </LinearLayout>

    <!-- Drawing area -->
    <com.hid.tabletpen.DrawPadView
        android:id="@+id/draw_pad"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#0F3460" />
</LinearLayout>
